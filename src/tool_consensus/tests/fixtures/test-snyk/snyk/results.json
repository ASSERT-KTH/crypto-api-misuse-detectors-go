{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SnykCode",
          "semanticVersion": "1.0.0",
          "version": "1.0.0"
        }
      },
      "results": [
        {
          "ruleId": "go/InsecureCipher",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "Using insecure cipher in crypto operations."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/crypto.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 15,
                  "endLine": 15,
                  "startColumn": 10,
                  "endColumn": 40
                }
              }
            }
          ]
        },
        {
          "ruleId": "go/TooPermissiveTrustManager",
          "ruleIndex": 1,
          "level": "warning",
          "message": {
            "text": "Using InsecureSkipVerify=true disables certificate validation."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/tls.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 25,
                  "endLine": 25,
                  "startColumn": 15,
                  "endColumn": 45
                }
              }
            }
          ]
        },
        {
          "ruleId": "go/InsecureTLSConfig",
          "ruleIndex": 2,
          "level": "error",
          "message": {
            "text": "Using insecure TLS protocol version."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/tls_config.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 30,
                  "endLine": 30,
                  "startColumn": 20,
                  "endColumn": 60
                }
              }
            }
          ]
        },
        {
          "ruleId": "go/HardcodedPassword/test",
          "ruleIndex": 3,
          "level": "note",
          "message": {
            "text": "Do not hardcode passwords in code. Found hardcoded saved in Password."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/auth.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 45,
                  "endLine": 45,
                  "startColumn": 10,
                  "endColumn": 30
                }
              }
            }
          ]
        },
        {
          "ruleId": "go/InsecureHash",
          "ruleIndex": 4,
          "level": "warning",
          "message": {
            "text": "Using bcrypt with too few iterations."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/password.go",
                  "uriBaseId": "%SRCROOT%"
                },
                "region": {
                  "startLine": 55,
                  "endLine": 55,
                  "startColumn": 10,
                  "endColumn": 50
                }
              }
            }
          ]
        }
      ]
    }
  ]
}